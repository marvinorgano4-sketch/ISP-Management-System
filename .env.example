# Flask Configuration
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///isp_billing.db

# Mikrotik Configuration
MIKROTIK_HOST=192.168.10.5
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=adminTaboo

# ZeroTier Configuration (Optional - for remote access)
# Get your network ID from ZeroTier Central after creating a network
# See ZEROTIER_SETUP.md for setup instructions
ZEROTIER_NETWORK_ID=a0cbf4b62a1234567
ZEROTIER_INTERFACE=zt0

# Firebase Configuration (Optional - for cloud database)
# Download your service account credentials JSON file from Firebase Console
# See FIREBASE_SETUP.md for setup instructions
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_PROJECT_ID=isp-billing-system-12345

# Server Configuration
BIND_HOST=0.0.0.0
BIND_PORT=5000
